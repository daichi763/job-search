# ===== Cloudflare側アプリのURL（デプロイ後のURL、またはローカル検証中は http://localhost:3000）=====
APP_URL=http://localhost:3000
# 取り込みAPIの認証トークン（Cloudflare側の INGEST_TOKEN と一致させる）
INGEST_TOKEN=change-me-please

# ===== OpenAI（採点用。Cloudflare側と同じ or 別キー）=====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-nano
# 検索プラン設計/PDF解析に使う優秀モデル（未指定だと gpt-5 で TLS 切断が起きやすい）
OPENAI_MODEL_SMART=gpt-5-mini

# ===== 検索対象ソース（カンマ区切り）=====
# circus,hitolink,jobins,kintone のうち有効化するものを指定。
SOURCES=circus,kintone

# ===== ①circusAGENT =====
CIRCUS_LOGIN_URL=https://circus-job.com
CIRCUS_ID=d.omori@dissectera.com
CIRCUS_PW=Dissectera123

# ===== ②ヒトリンク（HITO-Link エージェント）=====
# Azure AD B2C(OAuth2)経由でログイン→SESSION Cookieで内部API(Server Action)を叩く。
# ログインは /login を起点にすること（旧 /manage/home 指定は不可）。
HITOLINK_LOGIN_URL=https://agent.hito-link.jp/login
HITOLINK_ID=d.saito@dissectera.com
HITOLINK_PW=Ajjt2558

# ===== ③ジョビンズ =====
JOBINS_LOGIN_URL=https://jobins.jp/agent/login
JOBINS_ID=d.saito@dissectera.com
JOBINS_PW=Dissectera123@

# ===== ④kintone（自社DB）=====
# REST APIトークン認証（Playwright不要）。アプリ設定→APIトークンで発行。
KINTONE_SUBDOMAIN=kvln1
KINTONE_APP_ID=101
KINTONE_API_TOKEN=

# ポーリング間隔(ミリ秒)
POLL_INTERVAL=5000
# ヘッドレス(true=画面非表示 / false=デバッグ時ブラウザ表示)
HEADLESS=true
